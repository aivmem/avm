# Notification Service Environment Variables
# Copy this file to .env and customize values

# Redis Configuration
NOTIF_REDIS_HOST=localhost
NOTIF_REDIS_PORT=6379
NOTIF_REDIS_DB=0
NOTIF_REDIS_PASSWORD=
NOTIF_REDIS_QUEUE_NAME=notifications
NOTIF_REDIS_CONNECT_TIMEOUT=5.0
NOTIF_REDIS_SOCKET_TIMEOUT=5.0
NOTIF_REDIS_MAX_RETRIES=3
NOTIF_REDIS_RETRY_DELAY=0.5

# Circuit Breaker Configuration
NOTIF_CIRCUIT_BREAKER_THRESHOLD=5
NOTIF_CIRCUIT_BREAKER_TIMEOUT=30.0

# Service Configuration
NOTIF_SERVICE_NAME=notification-service
NOTIF_SERVICE_VERSION=1.0.0
NOTIF_LOG_LEVEL=INFO

# Processing Configuration
NOTIF_POLL_INTERVAL=1.0
NOTIF_BATCH_SIZE=10
NOTIF_MAX_RETRIES=3

# SMTP Configuration (for email delivery)
NOTIF_SMTP_HOST=localhost
NOTIF_SMTP_PORT=587
NOTIF_SMTP_USER=
NOTIF_SMTP_PASSWORD=
NOTIF_SMTP_FROM=noreply@example.com
